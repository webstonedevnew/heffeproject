# --- Supabase (create the project in an EU region, e.g. eu-central-1) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App ---
# Public base URL of the deployed app (used in emails and auth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Secret required by the reminder cron endpoint (/api/cron/reminders).
CRON_SECRET=generate-a-long-random-string

# --- Resend (EU-friendly transactional email) ---
RESEND_API_KEY=re_...
# Verified sender, e.g. "TOK Journal <forum@yourschooldomain.eu>"
EMAIL_FROM=TOK Journal <onboarding@resend.dev>

# --- Seed script only ---
SEED_TEACHER_EMAIL=teacher@example.com
SEED_TEACHER_NAME=The Teacher
# Set to "true" to also create demo students, a demo assignment and responses.
SEED_DEMO_DATA=true
